## mysql
MYSQL_DATABASE=ruoyi-vue-pro
MYSQL_ROOT_PASSWORD=CHANGE_ME_MYSQL_ROOT_PASSWORD

## server
JAVA_OPTS=-Xms512m -Xmx512m -Djava.security.egd=file:/dev/urandom
MASTER_DATASOURCE_USERNAME=CHANGE_ME_DB_USERNAME

## admin
NODE_ENV=production
PUBLIC_PATH=/
VUE_APP_TITLE=distribution管理系统
VUE_APP_BASE_API=/prod-api
VUE_APP_APP_NAME=/
VUE_APP_TENANT_ENABLE=true
VUE_APP_CAPTCHA_ENABLE=true
VUE_APP_DOC_ENABLE=true
VUE_APP_BAIDU_CODE=CHANGE_ME_BAIDU_CODE
